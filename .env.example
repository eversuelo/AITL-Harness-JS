# MongoDB
# MONGODB_URI is tried first; MONGODB_URI_FALLBACK is tried if the primary is
# unreachable (cluster down, IP not allowlisted, or local SRV-DNS failure). This lets
# the harness run local AND/OR Atlas without editing config — set Atlas as primary and
# local as fallback (or vice-versa).
MONGODB_URI=mongodb://localhost:27018/?directConnection=true
MONGODB_URI_FALLBACK=
MONGODB_DB=aitl

# Atlas tip: if the SRV form (mongodb+srv://) fails with `querySrv ECONNREFUSED`, your
# host resolver is refusing SRV lookups. Use the non-SRV seedlist form instead (Atlas →
# Connect → "older driver" string), which only needs A records:
# MONGODB_URI=mongodb://USER:PASS@host-00:27017,host-01:27017,host-02:27017/aitl?ssl=true&replicaSet=atlas-xxxx-shard-0&authSource=admin&retryWrites=true&w=majority

# Model routing
MODEL_PRIMARY=gemini
MODEL_SECONDARY=openai
MODEL_HOST=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FREE_MODEL=gemini-3.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Anthropic legacy provider
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMS=384
VOYAGE_API_KEY=

# Memory synthesis
MEMORY_MAX_DOCS=500
MEMORY_MAX_TOKENS=200000

# Export adapters
ENABLED_ADAPTERS=agents_md
