# MongoDB
MONGODB_URI=mongodb://localhost:27018/?directConnection=true
MONGODB_DB=aitl

# Model routing
MODEL_PRIMARY=gemini
MODEL_SECONDARY=openai
MODEL_HOST=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FREE_MODEL=gemini-3.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Anthropic legacy provider
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMS=384
VOYAGE_API_KEY=

# Memory synthesis
MEMORY_MAX_DOCS=500
MEMORY_MAX_TOKENS=200000

# Export adapters
ENABLED_ADAPTERS=agents_md
